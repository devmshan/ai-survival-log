{
  "schemaVersion": "0.1.0",
  "name": "Conversation Backup",
  "behavior": "create",
  "noteContentFormat": "# 대화 백업: {{title}}\\n\\n- **날짜:** {{date}}\\n- **성격:** 전체 대화 백업\\n- **원본 URL:** {{url}}\\n- **참여자:** {{author}}\\n- **타입:** journal\\n- **Ingest Target:** raw/journals\\n\\n---\\n\\n## 대화 원문 백업\\n\\n{{content}}\\n\\n---\\n\\n## 후속 처리 메모\\n\\n- wiki로 정리할 개념:\\n- 프로젝트 문서로 옮길 판단:\\n- 블로그 글 소재 여부:\\n",
  "properties": [
    {
      "name": "title",
      "value": "{{title}}",
      "type": "text"
    },
    {
      "name": "source",
      "value": "{{url}}",
      "type": "text"
    },
    {
      "name": "participants",
      "value": "{{author|split:\", \"|wikilink|join}}",
      "type": "multitext"
    },
    {
      "name": "captured",
      "value": "{{date}}",
      "type": "date"
    },
    {
      "name": "source_type",
      "value": "journal",
      "type": "text"
    },
    {
      "name": "ingest_target",
      "value": "raw/journals",
      "type": "text"
    },
    {
      "name": "recommended_harness",
      "value": "/wiki:ingest or manual backup flow",
      "type": "text"
    },
    {
      "name": "tags",
      "value": "conversation, backup, journal, raw-source",
      "type": "multitext"
    }
  ],
  "triggers": [],
  "noteNameFormat": "{{date}}-{{title}}",
  "path": "raw/journals"
}
