{
  "schemaVersion": "0.1.0",
  "name": "Generic Source Capture",
  "behavior": "create",
  "noteContentFormat": "# {{title}}\\n\\n- **Captured:** {{date}}\\n- **URL:** {{url}}\\n- **Author:** {{author}}\\n- **Published:** {{published}}\\n- **Suggested Target:** decide later\\n\\n## Classification Decision\\n\\n- Should this go to `raw/articles`, `raw/videos`, `raw/podcasts`, `raw/books`, or `raw/journals`?\\n\\n## Why Keep It\\n\\n-\\n\\n## Ingest Hint\\n\\n- What should `/wiki:ingest` focus on if this becomes a source?\\n\\n## Raw Clip\\n\\n{{content}}",
  "properties": [
    {
      "name": "title",
      "value": "{{title}}",
      "type": "text"
    },
    {
      "name": "source",
      "value": "{{url}}",
      "type": "text"
    },
    {
      "name": "author",
      "value": "{{author|split:\", \"|wikilink|join}}",
      "type": "multitext"
    },
    {
      "name": "published",
      "value": "{{published}}",
      "type": "date"
    },
    {
      "name": "captured",
      "value": "{{date}}",
      "type": "date"
    },
    {
      "name": "source_type",
      "value": "generic",
      "type": "text"
    },
    {
      "name": "ingest_target",
      "value": "decide-later",
      "type": "text"
    },
    {
      "name": "recommended_harness",
      "value": "classify first, then /wiki:ingest",
      "type": "text"
    },
    {
      "name": "description",
      "value": "{{description}}",
      "type": "text"
    },
    {
      "name": "tags",
      "value": "web-clipping, generic, inbox",
      "type": "multitext"
    }
  ],
  "triggers": [],
  "noteNameFormat": "{{date}}-{{title}}",
  "path": "raw/articles"
}
